# --- Infra/deploy creds (used by `alchemy deploy`; NEVER bound to the Worker) ---
# Cloudflare account to deploy to. Required when your creds can see more than one
# account, otherwise Alchemy picks one arbitrarily.
CLOUDFLARE_ACCOUNT_ID=
ALCHEMY_STATE_TOKEN=
ALCHEMY_STAGE=prod
# Required: encrypts GCAL_ICS_URL in Alchemy state before it is persisted.
# Keep it stable across deploys (changing it orphans previously-encrypted state).
ALCHEMY_PASSWORD=
# Only needed while the legacy Cloudflare Secrets Store still exists (its API
# rejects OAuth creds). Safe to leave unset once the store-teardown deploy has run.
CLOUDFLARE_API_TOKEN=

# --- Runtime secrets (dev: loaded into c.env via [secrets] required in
# --- wrangler.toml; prod: bound as Worker secrets by alchemy.run.ts) ---
# Google Calendar iCal feed. The private variant (".../private-<token>/basic.ics")
# is a credential — treat it like a password. The public URL yields "Busy"-only events.
GCAL_ICS_URL=
