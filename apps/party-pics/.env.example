# --- Infra/deploy creds (used by `alchemy deploy`; NEVER bound to the Worker) ---
# Cloudflare account to deploy to. Required when your creds can see more than one
# account, otherwise Alchemy picks one arbitrarily.
CLOUDFLARE_ACCOUNT_ID=
ALCHEMY_STATE_TOKEN=
ALCHEMY_STAGE=prod
# Required: encrypts the R2 secrets in Alchemy state before they are persisted.
# Keep it stable across deploys (changing it orphans previously-encrypted state).
ALCHEMY_PASSWORD=

# --- Worker runtime values (dev: loaded into c.env via [secrets] required in
# --- wrangler.toml; prod: bound by alchemy.run.ts, fails loud if unset) ---
# All env-invariant: the same account and the ONE remote R2 bucket serve dev and prod.
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
# R2 S3-API token (Cloudflare dashboard: R2 > Manage API tokens), scoped to the bucket.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
