{
  "name": "@zconsole/party-pics",
  "private": true,
  "description": "A opinionated starter template for building small mini apps for you and your friends. Built using Local First Auth, Cloudflare Workers, D1, and Durable Objects.",
  "license": "MIT",
  "keywords": [
    "antler",
    "local-first-auth",
    "cloudflare-workers",
    "d1",
    "durable-objects",
    "did",
    "decentralized-identity"
  ],
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "predev": "tsx scripts/build-client-if-missing.ts && pnpm --filter=@zconsole/party-pics-shared build",
    "predev:simulator": "tsx scripts/build-client-if-missing.ts && pnpm --filter=@zconsole/party-pics-shared build",
    "dev": "concurrently \"wrangler dev --local\" \"pnpm dev:client\" --names \"worker,client\" --prefix-colors \"blue,green\"",
    "dev:simulator": "concurrently \"wrangler dev --local\" \"pnpm dev:client:simulator\" --names \"worker,client\" --prefix-colors \"blue,green\"",
    "dev:client": "pnpm --filter=@zconsole/party-pics-client dev",
    "dev:client:simulator": "pnpm --filter=@zconsole/party-pics-client dev:simulator",
    "dev:server": "wrangler dev --local",
    "deploy:cloudflare": "pnpm build && alchemy deploy",
    "destroy:cloudflare": "alchemy destroy",
    "build": "pnpm run --filter=@zconsole/party-pics-shared build && pnpm run --filter=@zconsole/party-pics-client build",
    "build:client": "pnpm --filter=@zconsole/party-pics-client build",
    "db:generate-migrations": "pnpm --filter=@zconsole/party-pics-server db:generate-migrations",
    "db:run-migrations": "tsx scripts/run-dev-migrations.ts",
    "setup-project": "tsx scripts/setup.ts"
  },
  "dependencies": {
    "@noble/curves": "^2.0.1",
    "base58-universal": "^2.0.0",
    "drizzle-orm": "^0.44.7",
    "jwt-decode": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "alchemy": "0.77.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "wrangler": "^4.53.0"
  }
}
